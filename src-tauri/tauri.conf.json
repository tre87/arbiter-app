{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arbiter",
  "version": "1.0.8",
  "identifier": "com.arbiter.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Arbiter",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 560,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 14, "y": 22 },
        "hiddenTitle": true,
        "transparent": false,
        "visible": false,
        "backgroundColor": "#121212"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
